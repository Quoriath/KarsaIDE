{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KarsaIDE",
  "version": "0.1.0",
  "identifier": "com.karsa.ide",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Karsa IDE",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1024,
        "minHeight": 768
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "core:event:allow-listen",
            "core:event:allow-emit",
            "core:window:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
